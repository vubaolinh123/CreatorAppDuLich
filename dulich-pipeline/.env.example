# ── AI Models ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-key

# ── Voice Providers ───────────────────────────────────────────────────────────
# Primary: Vbee.ai (tiếng Việt native)
VBEE_API_KEY=your-vbee-key
VOICE_PROVIDER=vbee          # vbee | elevenlabs | mock

# Secondary: ElevenLabs (bilingual / voice clone)
ELEVENLABS_API_KEY=your-elevenlabs-key

# ── Creator Voice IDs ─────────────────────────────────────────────────────────
# Vbee.ai built-in voice codes (no key needed for standard voices)
CREATOR1_VOICE_ID=hn_female_lananh     # Lan Anh — Vbee.ai Hà Nội nữ
CREATOR2_VOICE_ID=hn_male_minhtuan     # Minh Tuấn — Vbee.ai Hà Nội nam
CREATOR3_VOICE_ID=                     # Thu Hà — ElevenLabs (Instant Clone ID)
CREATOR4_VOICE_ID=hcm_male_ducanh      # Đức Anh — Vbee.ai HCM nam
CREATOR5_VOICE_ID=hn_female_ngocmai    # Ngọc Mai — Vbee.ai Hà Nội nữ

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=dulichapp
# For MongoDB Atlas: MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/

# ── Google APIs ───────────────────────────────────────────────────────────────
GOOGLE_SHEET_ID=your-sheet-id
GOOGLE_CREDENTIALS_PATH=credentials.json

# ── Social Publishing ─────────────────────────────────────────────────────────
AYRSHARE_API_KEY=your-ayrshare-key

# ── Dashboard ─────────────────────────────────────────────────────────────────
DASHBOARD_URL=http://localhost:3000

# ── Resource Config ───────────────────────────────────────────────────────────
MAX_WORKERS=2          # Số jobs chạy song song
RAM_GB=4.0             # RAM tối đa (GB)
CPU_CORES=2            # Số CPU cores
